# Copy this file to .env before running docker compose or local dev.
# Never commit .env to version control.


# ── PostgreSQL (used by Docker Compose) ───────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager


# ── Backend ────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/taskmanager
JWT_SECRET_KEY=change-this-to-a-random-secret-of-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173


# ── Frontend ───────────────────────────────────

VITE_API_URL=http://localhost:8000/api/v1
